{
  "expo": {
    "name": "TrustRent",
    "slug": "trustrent",
    "version": "1.0.0",
    "orientation": "portrait",
     "icon": "./assets/icon.png",
    "scheme": "trustrent",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#185FA5"
      },
      "package": "com.vipinkumar.trustrent"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#185FA5"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "31d493ee-7914-46b1-b421-f1e8d9f01af1"
      }
    }
  }
}
